<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_account_move_form_engagement" model="ir.ui.view">
        <field name="name">account.move.form.180dc.engagement</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_engagement_id" domain="[('client_company_id', '=', partner_id)]"/>
            </xpath>
        </field>
    </record>

    <record id="x_180dc_account_move_tree_engagement" model="ir.ui.view">
        <field name="name">account.move.tree.180dc.engagement</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="x_engagement_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
