<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_engagement_cycle_action" model="ir.actions.act_window">
        <field name="name">Engagement Cycles</field>
        <field name="res_model">x_180dc.engagement.cycle</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_engagement_cycle_view_list" model="ir.ui.view">
        <field name="name">x.180dc.engagement.cycle.list</field>
        <field name="model">x_180dc.engagement.cycle</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="date_start_month"/>
                <field name="date_start_day"/>
                <field name="date_end_month"/>
                <field name="date_end_day"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_engagement_cycle_view_form" model="ir.ui.view">
        <field name="name">x.180dc.engagement.cycle.form</field>
        <field name="model">x_180dc.engagement.cycle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group string="Calendar Bounds">
                        <field name="date_start_month"/>
                        <field name="date_start_day"/>
                        <field name="date_end_month"/>
                        <field name="date_end_day"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_engagement_cycle_menu"
        name="Engagement Cycles"
        parent="x_180dc_engagement_config_menu"
        action="x_180dc_engagement_cycle_action"
        sequence="30"
        groups="base.group_system,group_180dc_engagement_structural"
    />
</odoo>
