<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_engagement_action" model="ir.actions.act_window">
        <field name="name">Engagements</field>
        <field name="res_model">x_180dc.engagement</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <record id="x_180dc_engagement_project_type_action" model="ir.actions.act_window">
        <field name="name">Project Types</field>
        <field name="res_model">x_180dc.engagement.project_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_engagement_consulting_technique_action" model="ir.actions.act_window">
        <field name="name">Consulting Techniques</field>
        <field name="res_model">x_180dc.engagement.consulting_technique</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_engagement_view_search" model="ir.ui.view">
        <field name="name">x.180dc.engagement.search</field>
        <field name="model">x_180dc.engagement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_company_id"/>
                <field name="client_contact_ids"/>
                <field name="lead_id"/>
                <field name="cycle_id"/>
                <field name="cycle_year"/>
                <field name="project_type_ids"/>
                <field name="consulting_technique_ids"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="x_180dc_engagement_view_list" model="ir.ui.view">
        <field name="name">x.180dc.engagement.list</field>
        <field name="model">x_180dc.engagement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_company_id"/>
                <field name="cycle_id"/>
                <field name="cycle_year" widget="char" string="Year"/>
                <field name="project_type_ids" widget="many2many_tags" optional="hide"/>
                <field name="consulting_technique_ids" widget="many2many_tags" optional="hide"/>
                <field name="invoice_count"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_engagement_view_form" model="ir.ui.view">
        <field name="name">x.180dc.engagement.form</field>
        <field name="model">x_180dc.engagement</field>
        <field name="arch" type="xml">
            <form string="Engagement">
                <header>
                    <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o" string="Invoices"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="client_company_id"/>
                            <field name="client_contact_ids" widget="many2many_tags"/>
                            <field name="lead_id" options="{'no_open': False}"/>
                            <field name="member_ids" widget="many2many_tags"/>
                            <field name="project_type_ids" widget="many2many_tags"/>
                            <field name="consulting_technique_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="cycle_id"/>
                            <field name="cycle_year" options="{'type': 'number'}"/>
                            <field name="active"/>
                            <field name="date_start" invisible="1"/>
                            <field name="date_end" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary">
                            <field name="summary" placeholder="Project summary, objectives, outcomes..."/>
                        </page>
                        <page string="Files">
                            <group string="Storage Policy">
                                <div class="o_form_label">Store engagement files in Google Drive only. Paste share links below; file uploads are disabled in Odoo.</div>
                            </group>
                            <group string="Client Contract">
                                <field name="contract_drive_link" widget="url" placeholder="https://drive.google.com/..."/>
                            </group>
                            <group string="Scoping Document">
                                <field name="scoping_drive_link" widget="url" placeholder="https://drive.google.com/..."/>
                            </group>
                            <group string="Final Presentation">
                                <field name="final_presentation_drive_link" widget="url" placeholder="https://drive.google.com/..."/>
                            </group>
                            <group string="Other">
                                <field name="other_drive_link" widget="url" placeholder="https://drive.google.com/..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="x_180dc_engagement_project_type_view_list" model="ir.ui.view">
        <field name="name">x.180dc.engagement.project.type.list</field>
        <field name="model">x_180dc.engagement.project_type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_engagement_project_type_view_form" model="ir.ui.view">
        <field name="name">x.180dc.engagement.project.type.form</field>
        <field name="model">x_180dc.engagement.project_type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_engagement_consulting_technique_view_list" model="ir.ui.view">
        <field name="name">x.180dc.engagement.consulting.technique.list</field>
        <field name="model">x_180dc.engagement.consulting_technique</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="x_short_description" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_engagement_consulting_technique_view_form" model="ir.ui.view">
        <field name="name">x.180dc.engagement.consulting.technique.form</field>
        <field name="model">x_180dc.engagement.consulting_technique</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="x_short_description"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="x_long_description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="x_180dc_menu_root" name="180DC" sequence="60" groups="base.group_system,group_180dc_engagement_operational,group_180dc_engagement_structural,group_180dc_engagement_project_leader,hr.group_hr_user,hr.group_hr_manager"/>
    <menuitem id="x_180dc_engagement_menu" name="Engagements" parent="x_180dc_menu_root" action="x_180dc_engagement_action" sequence="10" groups="base.group_system,group_180dc_engagement_operational,group_180dc_engagement_structural,group_180dc_engagement_project_leader"/>
    <menuitem id="x_180dc_engagement_config_menu" name="Configuration" parent="x_180dc_menu_root" sequence="90" groups="base.group_system,group_180dc_engagement_structural"/>
    <menuitem id="x_180dc_engagement_project_type_menu" name="Project Types" parent="x_180dc_engagement_config_menu" action="x_180dc_engagement_project_type_action" sequence="10" groups="base.group_system,group_180dc_engagement_structural"/>
    <menuitem id="x_180dc_engagement_consulting_technique_menu" name="Consulting Techniques" parent="x_180dc_engagement_config_menu" action="x_180dc_engagement_consulting_technique_action" sequence="20" groups="base.group_system,group_180dc_engagement_structural"/>
</odoo>
