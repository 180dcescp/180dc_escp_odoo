<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_operating_model_res_users_form" model="ir.ui.view">
        <field name="name">res.users.form.180dc.operating.model</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="180DC Roles" name="x_180dc_roles">
                    <group>
                        <field name="x_available_business_group_ids" invisible="1"/>
                        <field
                            name="x_manual_business_group_ids"
                            widget="many2many_tags"
                            domain="[('id', 'in', x_available_business_group_ids)]"
                            options="{'no_create': True}"
                        />
                        <div class="o_form_label">Use this page to assign only the approved 180DC business roles. Native Odoo group definitions and direct native-group editing are reserved to the protected superadmin.</div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
