<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_operating_model_res_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.180dc.operating.model</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Email Marketing">
                    <group>
                        <field name="x_mailing_opt_out"/>
                        <field name="x_mailing_list_ids" widget="many2many_tags"/>
                        <field name="x_derived_mailing_list_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
