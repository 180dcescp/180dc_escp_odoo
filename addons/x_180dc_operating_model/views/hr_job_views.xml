<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_operating_model_hr_job_form" model="ir.ui.view">
        <field name="name">hr.job.form.180dc.operating.model</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='recruitment_page']" position="inside">
                <group string="180DC Recruitment Pipeline">
                    <group>
                        <field name="x_recruitment_profile_id"/>
                        <field name="x_recruitment_owner_scope"/>
                        <field name="x_second_round_owner_scope"/>
                        <field name="x_application_survey_title"/>
                        <field name="x_interview_survey_title"/>
                        <field name="x_case_survey_title"/>
                        <field name="x_second_round_survey_title"/>
                        <field name="x_application_question_1"/>
                        <field name="x_application_question_2"/>
                        <field name="x_application_question_3"/>
                    </group>
                    <group>
                        <field name="x_personal_fit_prompt"/>
                        <field name="x_case_study_prompt"/>
                        <field name="x_second_round_prompt"/>
                    </group>
                </group>
                <group string="Linked Surveys">
                    <group>
                        <field name="x_application_survey_id" readonly="1"/>
                        <field name="survey_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="x_case_survey_id" readonly="1"/>
                        <field name="x_second_round_survey_id" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
