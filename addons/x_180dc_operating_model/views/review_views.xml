<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_review_template_view_list" model="ir.ui.view">
        <field name="name">x.180dc.review.template.list</field>
        <field name="model">x_180dc.review.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="review_scope"/>
                <field name="survey_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_review_template_view_form" model="ir.ui.view">
        <field name="name">x.180dc.review.template.form</field>
        <field name="model">x_180dc.review.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="review_scope"/>
                        <field name="survey_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_review_assignment_view_list" model="ir.ui.view">
        <field name="name">x.180dc.review.assignment.list</field>
        <field name="model">x_180dc.review.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="review_scope"/>
                <field name="season_id"/>
                <field name="subject_employee_id"/>
                <field name="reviewer_employee_id"/>
                <field name="engagement_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_review_assignment_view_form" model="ir.ui.view">
        <field name="name">x.180dc.review.assignment.form</field>
        <field name="model">x_180dc.review.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_cancelled" type="object" string="Cancel" invisible="state == 'cancelled'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="template_id"/>
                            <field name="review_scope" readonly="1"/>
                            <field name="season_id"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="subject_employee_id"/>
                            <field name="reviewer_employee_id"/>
                            <field name="engagement_id"/>
                            <field name="survey_user_input_id" readonly="1"/>
                            <field name="survey_url" widget="url" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_review_template_action" model="ir.actions.act_window">
        <field name="name">Review Templates</field>
        <field name="res_model">x_180dc.review.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_review_assignment_action" model="ir.actions.act_window">
        <field name="name">Reviews</field>
        <field name="res_model">x_180dc.review.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="x_180dc_review_menu" name="Reviews" parent="x_180dc_engagement.x_180dc_menu_root" sequence="20" action="x_180dc_review_assignment_action" groups="base.group_system,hr.group_hr_user,hr.group_hr_manager,x_180dc_engagement.group_180dc_engagement_operational,x_180dc_engagement.group_180dc_engagement_structural,x_180dc_engagement.group_180dc_engagement_project_leader"/>
    <menuitem id="x_180dc_feedback_menu_root" name="180DC Feedback" sequence="85" action="x_180dc_review_assignment_action" groups="base.group_user"/>
    <menuitem id="x_180dc_review_template_menu" name="Review Templates" parent="x_180dc_engagement.x_180dc_engagement_config_menu" sequence="30" action="x_180dc_review_template_action" groups="base.group_system,hr.group_hr_manager"/>
</odoo>
