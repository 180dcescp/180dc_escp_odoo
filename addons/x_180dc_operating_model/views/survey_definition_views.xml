<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_survey_definition_action" model="ir.actions.act_window">
        <field name="name">Survey Definitions</field>
        <field name="res_model">x_180dc.survey.definition</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_survey_definition_view_list" model="ir.ui.view">
        <field name="name">x.180dc.survey.definition.list</field>
        <field name="model">x_180dc.survey.definition</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="key"/>
                <field name="title"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_survey_definition_view_form" model="ir.ui.view">
        <field name="name">x.180dc.survey.definition.form</field>
        <field name="model">x_180dc.survey.definition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="key"/>
                        <field name="title"/>
                        <field name="active"/>
                    </group>
                    <group string="Questions">
                        <field name="question_ids">
                            <list editable="bottom">
                                <field name="sequence"/>
                                <field name="key"/>
                                <field name="title"/>
                                <field name="question_type"/>
                                <field name="mandatory"/>
                            </list>
                            <form>
                                <sheet>
                                    <group>
                                        <field name="sequence"/>
                                        <field name="key"/>
                                        <field name="question_type"/>
                                        <field name="mandatory"/>
                                    </group>
                                    <group>
                                        <field name="title"/>
                                        <field name="description"/>
                                        <field name="placeholder"/>
                                    </group>
                                    <group string="Suggested Answers">
                                        <field name="answer_ids">
                                            <list editable="bottom">
                                                <field name="sequence"/>
                                                <field name="value"/>
                                            </list>
                                        </field>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_survey_definition_menu"
        name="Survey Definitions"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_survey_definition_action"
        sequence="34"
        groups="base.group_system"
    />
</odoo>
