<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_consulting_reviewer_policy_action" model="ir.actions.act_window">
        <field name="name">Consulting Reviewer Policies</field>
        <field name="res_model">x_180dc.consulting_reviewer_policy</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_consulting_reviewer_policy_view_list" model="ir.ui.view">
        <field name="name">x.180dc.consulting.reviewer.policy.list</field>
        <field name="model">x_180dc.consulting_reviewer_policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="rule_key"/>
                <field name="name"/>
                <field name="pool_scope"/>
                <field name="priority"/>
                <field name="department_ids" widget="many2many_tags"/>
                <field name="job_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_consulting_reviewer_policy_view_form" model="ir.ui.view">
        <field name="name">x.180dc.consulting.reviewer.policy.form</field>
        <field name="model">x_180dc.consulting_reviewer_policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="rule_key"/>
                        <field name="name"/>
                        <field name="pool_scope"/>
                        <field name="priority"/>
                        <field name="active"/>
                    </group>
                    <group string="Eligibility">
                        <field name="department_ids" widget="many2many_tags"/>
                        <field name="job_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_consulting_reviewer_policy_menu"
        name="Consulting Reviewer Policies"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_consulting_reviewer_policy_action"
        sequence="36"
        groups="base.group_system"
    />
</odoo>
