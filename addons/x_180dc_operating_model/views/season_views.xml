<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_season_view_list" model="ir.ui.view">
        <field name="name">x.180dc.season.list</field>
        <field name="model">x_180dc.season</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cycle_id"/>
                <field name="year"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_season_view_form" model="ir.ui.view">
        <field name="name">x.180dc.season.form</field>
        <field name="model">x_180dc.season</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="cycle_id"/>
                        <field name="year"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_season_action" model="ir.actions.act_window">
        <field name="name">Seasons</field>
        <field name="res_model">x_180dc.season</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="x_180dc_season_menu" name="Seasons" parent="x_180dc_engagement.x_180dc_engagement_config_menu" action="x_180dc_season_action" sequence="5" groups="base.group_system,hr.group_hr_manager,x_180dc_engagement.group_180dc_engagement_structural"/>
</odoo>
