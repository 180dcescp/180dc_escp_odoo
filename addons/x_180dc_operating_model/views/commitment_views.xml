<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_commitment_assignment_view_list" model="ir.ui.view">
        <field name="name">x.180dc.commitment.assignment.list</field>
        <field name="model">x_180dc.commitment.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="season_id"/>
                <field name="next_season_id"/>
                <field name="summer_break_allowed"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_commitment_assignment_view_form" model="ir.ui.view">
        <field name="name">x.180dc.commitment.assignment.form</field>
        <field name="model">x_180dc.commitment.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_cancelled" type="object" string="Cancel" invisible="state == 'cancelled'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="season_id"/>
                            <field name="next_season_id"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="survey_id"/>
                            <field name="survey_user_input_id" readonly="1"/>
                            <field name="summer_break_allowed" readonly="1"/>
                            <field name="survey_url" widget="url" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_commitment_assignment_action" model="ir.actions.act_window">
        <field name="name">Commitment Surveys</field>
        <field name="res_model">x_180dc.commitment.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="x_180dc_commitment_menu" name="Commitment Surveys" parent="x_180dc_engagement.x_180dc_menu_root" sequence="25" action="x_180dc_commitment_assignment_action" groups="base.group_system,hr.group_hr_user,hr.group_hr_manager"/>
</odoo>
