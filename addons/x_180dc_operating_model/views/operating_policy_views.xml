<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_operating_policy_action" model="ir.actions.act_window">
        <field name="name">Operating Policy</field>
        <field name="res_model">x_180dc.operating_policy</field>
        <field name="view_mode">form</field>
    </record>

    <record id="x_180dc_operating_policy_view_form" model="ir.ui.view">
        <field name="name">x.180dc.operating.policy.form</field>
        <field name="model">x_180dc.operating_policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="alumni_cooldown_months"/>
                    </group>
                    <group string="Allowed Employee Email Domains">
                        <field name="allowed_email_domain_ids">
                            <list editable="bottom">
                                <field name="domain"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_operating_policy_menu"
        name="Operating Policy"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_operating_policy_action"
        sequence="32"
        groups="base.group_system"
    />
</odoo>
