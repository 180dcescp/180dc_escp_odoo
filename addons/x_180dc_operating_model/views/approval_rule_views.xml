<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_approval_scope_action" model="ir.actions.act_window">
        <field name="name">Approval Scopes</field>
        <field name="res_model">x_180dc.approval.scope</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_approval_scope_view_list" model="ir.ui.view">
        <field name="name">x.180dc.approval.scope.list</field>
        <field name="model">x_180dc.approval.scope</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_approval_scope_view_form" model="ir.ui.view">
        <field name="name">x.180dc.approval.scope.form</field>
        <field name="model">x_180dc.approval.scope</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group string="Approver Rules">
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="rule_key"/>
                                <field name="approver_department_ids" widget="many2many_tags"/>
                                <field name="approver_job_ids" widget="many2many_tags"/>
                                <field name="match_requested_department"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="x_180dc_promotion_approval_rule_action" model="ir.actions.act_window">
        <field name="name">Promotion Approval Rules</field>
        <field name="res_model">x_180dc.promotion_approval_rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_promotion_approval_rule_view_list" model="ir.ui.view">
        <field name="name">x.180dc.promotion.approval.rule.list</field>
        <field name="model">x_180dc.promotion_approval_rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="rule_key"/>
                <field name="requested_job_id"/>
                <field name="requested_department_id"/>
                <field name="requested_work_location_id"/>
                <field name="approval_scope_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_promotion_approval_rule_view_form" model="ir.ui.view">
        <field name="name">x.180dc.promotion.approval.rule.form</field>
        <field name="model">x_180dc.promotion_approval_rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="rule_key"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group string="Target Scope">
                        <field name="requested_job_id"/>
                        <field name="requested_department_id"/>
                        <field name="requested_work_location_id"/>
                    </group>
                    <group string="Approval">
                        <field name="approval_scope_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_approval_scope_menu"
        name="Approval Scopes"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_approval_scope_action"
        sequence="34"
        groups="base.group_system"
    />

    <menuitem
        id="x_180dc_promotion_approval_rule_menu"
        name="Promotion Approval Rules"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_promotion_approval_rule_action"
        sequence="35"
        groups="base.group_system"
    />
</odoo>
