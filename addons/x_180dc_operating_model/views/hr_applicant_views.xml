<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_operating_model_hr_applicant_form" model="ir.ui.view">
        <field name="name">hr.applicant.form.180dc.operating.model</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_application_survey" type="object" string="Send Essay Survey" invisible="not x_application_survey_id"/>
                <button name="action_send_survey" type="object" string="Send Personal Fit Survey" invisible="not survey_id"/>
                <button name="action_send_case_survey" type="object" string="Send Case Study Survey" invisible="not x_case_survey_id"/>
                <button name="action_send_second_round_survey" type="object" string="Send Second Round Survey" invisible="not x_pl_potential or not x_second_round_survey_id"/>
            </xpath>
            <xpath expr="//field[@name='email_from']" position="after">
                <field name="x_escp_email"/>
                <field name="x_180dc_email"/>
                <field name="x_program"/>
                <field name="x_estimated_graduation_date"/>
                <field name="x_work_location_id"/>
                <field name="x_pl_potential"/>
            </xpath>
        </field>
    </record>
</odoo>
