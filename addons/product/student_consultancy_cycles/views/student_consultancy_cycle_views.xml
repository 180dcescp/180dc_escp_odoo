<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_consultancy_cycle_schema_tree" model="ir.ui.view">
        <field name="name">student.consultancy.cycle.schema.tree</field>
        <field name="model">student.consultancy.cycle.schema</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="mode"/>
                <field name="start_month"/>
                <field name="start_day"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_student_consultancy_cycle_schema_form" model="ir.ui.view">
        <field name="name">student.consultancy.cycle.schema.form</field>
        <field name="model">student.consultancy.cycle.schema</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="mode"/>
                        <field name="start_month"/>
                        <field name="start_day"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Generated Cycles">
                        <field name="cycle_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_student_consultancy_cycle_tree" model="ir.ui.view">
        <field name="name">student.consultancy.cycle.tree</field>
        <field name="model">student.consultancy.cycle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="schema_id"/>
                <field name="reference_year"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="view_student_consultancy_cycle_period_tree" model="ir.ui.view">
        <field name="name">student.consultancy.cycle.period.tree</field>
        <field name="model">student.consultancy.cycle.period</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="schema_id"/>
                <field name="sequence"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_student_consultancy_cycle_schemas" model="ir.actions.act_window">
        <field name="name">Cycle Schemas</field>
        <field name="res_model">student.consultancy.cycle.schema</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_student_consultancy_cycle_periods" model="ir.actions.act_window">
        <field name="name">Cycle Periods</field>
        <field name="res_model">student.consultancy.cycle.period</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem
        id="menu_student_consultancy_cycles_root"
        name="Cycles"
        parent="student_consultancy_core.menu_student_consultancy_root"
        action="action_student_consultancy_cycle_schemas"
        sequence="5"
        groups="student_consultancy_core.group_student_consultancy_manager"
    />

    <menuitem
        id="menu_student_consultancy_cycle_periods"
        name="Periods"
        parent="menu_student_consultancy_cycles_root"
        action="action_student_consultancy_cycle_periods"
        sequence="10"
        groups="student_consultancy_core.group_student_consultancy_manager"
    />
</odoo>
