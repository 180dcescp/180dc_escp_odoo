<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_student_consultancy_user" model="res.groups">
        <field name="name">Student Consultancy User</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_student_consultancy_manager" model="res.groups">
        <field name="name">Student Consultancy Manager</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('student_consultancy_core.group_student_consultancy_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_student_consultancy_hidden_app" model="res.groups">
        <field name="name">Student Consultancy Hidden App</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>
</odoo>
