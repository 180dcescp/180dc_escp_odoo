<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_consultancy_project_type_tree" model="ir.ui.view">
        <field name="name">student.consultancy.project.type.tree</field>
        <field name="model">student.consultancy.project.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_student_consultancy_project_tree" model="ir.ui.view">
        <field name="name">student.consultancy.project.tree</field>
        <field name="model">student.consultancy.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type_id"/>
                <field name="client_partner_id"/>
                <field name="cycle_period_id"/>
                <field name="state"/>
                <field name="public_visibility"/>
            </list>
        </field>
    </record>

    <record id="view_student_consultancy_project_form" model="ir.ui.view">
        <field name="name">student.consultancy.project.form</field>
        <field name="model">student.consultancy.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="type_id"/>
                        <field name="client_partner_id"/>
                        <field name="lead_id"/>
                        <field name="cycle_period_id"/>
                        <field name="state"/>
                        <field name="public_visibility"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="summary"/>
                    </group>
                    <group string="Staffing">
                        <field name="staffing_assignment_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_student_consultancy_staffing_assignment_tree" model="ir.ui.view">
        <field name="name">student.consultancy.staffing.assignment.tree</field>
        <field name="model">student.consultancy.staffing.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="project_id"/>
                <field name="member_id"/>
                <field name="membership_id"/>
                <field name="role_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_student_consultancy_staffing_assignment_form" model="ir.ui.view">
        <field name="name">student.consultancy.staffing.assignment.form</field>
        <field name="model">student.consultancy.staffing.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" invisible="state != 'proposed'"/>
                    <button name="action_release" type="object" string="Release" invisible="state == 'released'"/>
                    <field name="state" widget="statusbar" statusbar_visible="proposed,confirmed,released"/>
                </header>
                <sheet>
                    <group>
                        <field name="project_id"/>
                        <field name="member_id"/>
                        <field name="membership_id"/>
                        <field name="role_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_consultancy_projects" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">student.consultancy.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_student_consultancy_staffing_assignments" model="ir.actions.act_window">
        <field name="name">Staffing Assignments</field>
        <field name="res_model">student.consultancy.staffing.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_student_consultancy_project_types" model="ir.actions.act_window">
        <field name="name">Project Types</field>
        <field name="res_model">student.consultancy.project.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_student_consultancy_projects_root"
        name="Projects"
        parent="student_consultancy_core.menu_student_consultancy_root"
        sequence="30"
    />

    <menuitem
        id="menu_student_consultancy_projects"
        name="Projects"
        parent="menu_student_consultancy_projects_root"
        action="action_student_consultancy_projects"
        sequence="10"
    />

    <menuitem
        id="menu_student_consultancy_staffing_assignments"
        name="Staffing"
        parent="menu_student_consultancy_projects_root"
        action="action_student_consultancy_staffing_assignments"
        sequence="20"
    />

    <menuitem
        id="menu_student_consultancy_project_types"
        name="Project Types"
        parent="menu_student_consultancy_projects_root"
        action="action_student_consultancy_project_types"
        sequence="30"
        groups="student_consultancy_core.group_student_consultancy_manager"
    />
</odoo>
