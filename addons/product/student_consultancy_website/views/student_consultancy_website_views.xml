<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_student_consultancy_website" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.student.consultancy.website</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Student Consultancy Website" name="student_consultancy_website" groups="base.group_system">
                    <block title="Public Chapter Profile">
                        <setting string="Organization Name">
                            <field name="sc_organization_name"/>
                        </setting>
                        <setting string="Public Contact Email">
                            <field name="sc_contact_email"/>
                        </setting>
                        <setting string="Website URL">
                            <field name="sc_website_url"/>
                        </setting>
                        <setting string="Tagline">
                            <field name="sc_website_tagline"/>
                        </setting>
                        <setting string="Chapter Profile">
                            <field name="sc_chapter_profile"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_student_consultancy_public_members" model="ir.actions.act_window">
        <field name="name">Public Members</field>
        <field name="res_model">student.consultancy.member</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("is_public", "=", True)]</field>
    </record>

    <record id="action_student_consultancy_public_positions" model="ir.actions.act_window">
        <field name="name">Public Positions</field>
        <field name="res_model">student.consultancy.position</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("is_public", "=", True)]</field>
    </record>

    <record id="action_student_consultancy_public_projects" model="ir.actions.act_window">
        <field name="name">Public Projects</field>
        <field name="res_model">student.consultancy.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("public_visibility", "=", "public")]</field>
    </record>

    <menuitem
        id="menu_student_consultancy_website_root"
        name="Website"
        parent="student_consultancy_core.menu_student_consultancy_root"
        sequence="50"
    />

    <menuitem
        id="menu_student_consultancy_website_members"
        name="Public Members"
        parent="menu_student_consultancy_website_root"
        action="action_student_consultancy_public_members"
        sequence="10"
    />

    <menuitem
        id="menu_student_consultancy_website_positions"
        name="Public Positions"
        parent="menu_student_consultancy_website_root"
        action="action_student_consultancy_public_positions"
        sequence="20"
    />

    <menuitem
        id="menu_student_consultancy_website_projects"
        name="Public Projects"
        parent="menu_student_consultancy_website_root"
        action="action_student_consultancy_public_projects"
        sequence="30"
    />
</odoo>
