<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_website_kpi_definition_action" model="ir.actions.act_window">
        <field name="name">Website KPI Definitions</field>
        <field name="res_model">x_180dc.website.kpi_definition</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="x_180dc_website_kpi_definition_view_list" model="ir.ui.view">
        <field name="name">x.180dc.website.kpi.definition.list</field>
        <field name="model">x_180dc.website.kpi_definition</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="label"/>
                <field name="key"/>
                <field name="emphasis"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_website_kpi_definition_view_form" model="ir.ui.view">
        <field name="name">x.180dc.website.kpi.definition.form</field>
        <field name="model">x_180dc.website.kpi_definition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="label"/>
                        <field name="key"/>
                        <field name="emphasis"/>
                        <field name="suffix"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="internal_description"/>
                        <field name="external_description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="x_180dc_website_kpi_definition_menu"
        name="Website KPI Definitions"
        parent="x_180dc_engagement.x_180dc_engagement_config_menu"
        action="x_180dc_website_kpi_definition_action"
        sequence="82"
        groups="base.group_system"
    />
</odoo>
