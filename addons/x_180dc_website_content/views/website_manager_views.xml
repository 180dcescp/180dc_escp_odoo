<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_website_dashboard_action" model="ir.actions.client">
        <field name="name">Website Manager Dashboard</field>
        <field name="tag">x_180dc_website_dashboard</field>
    </record>

    <record id="x_180dc_website_engagement_list" model="ir.ui.view">
        <field name="name">x.180dc.engagement.list.website.manager</field>
        <field name="model">x_180dc.engagement</field>
        <field name="arch" type="xml">
            <list default_order="date_start desc, id desc">
                <field name="name"/>
                <field name="client_company_id"/>
                <field name="project_type_ids" widget="many2many_tags"/>
                <field name="x_public_visibility"/>
                <field name="x_effective_public_visibility"/>
                <field name="x_scheduled_public_visibility"/>
                <field name="x_scheduled_public_visibility_at"/>
                <field name="x_public_slug"/>
                <field name="x_featured"/>
                <field name="date_start"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_website_engagement_search" model="ir.ui.view">
        <field name="name">x.180dc.engagement.search.website.manager</field>
        <field name="model">x_180dc.engagement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_company_id"/>
                <field name="project_type_ids"/>
                <field name="x_public_visibility"/>
                <field name="x_effective_public_visibility"/>
                <filter name="filter_publishable" string="Publishable Projects" domain="[('x_effective_public_visibility', 'in', ['anonymized', 'full_disclosure']), ('x_public_slug', '!=', False)]"/>
                <filter name="filter_client_only" string="Client Mentions" domain="[('x_effective_public_visibility', '=', 'client_only')]"/>
                <filter name="filter_scheduled" string="Scheduled Change" domain="[('x_scheduled_public_visibility', '!=', False)]"/>
                <filter name="filter_missing_slug" string="Missing Slug" domain="[('x_public_visibility', 'in', ['anonymized', 'full_disclosure']), ('x_public_slug', '=', False)]"/>
                <filter name="filter_logo_risk" string="Logo Fallback Risk" domain="[('x_public_visibility', 'in', ['client_only', 'full_disclosure']), ('client_company_id', '!=', False), ('client_company_id.x_public_logo_url', '=', False)]"/>
                <separator/>
                <filter name="group_by_configured_disclosure" string="Configured Disclosure" context="{'group_by': 'x_public_visibility'}"/>
                <filter name="group_by_effective_disclosure" string="Effective Disclosure" context="{'group_by': 'x_effective_public_visibility'}"/>
                <filter name="group_by_client" string="Client" context="{'group_by': 'client_company_id'}"/>
            </search>
        </field>
    </record>

    <record id="x_180dc_website_engagement_action" model="ir.actions.act_window">
        <field name="name">Engagement Publishing</field>
        <field name="res_model">x_180dc.engagement</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="x_180dc_website_engagement_list"/>
        <field name="search_view_id" ref="x_180dc_website_engagement_search"/>
        <field name="context">{'search_default_filter_publishable': 1}</field>
    </record>

    <record id="x_180dc_website_team_contract_list" model="ir.ui.view">
        <field name="name">hr.contract.list.website.manager.team</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <list default_order="date_start desc, id desc">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="x_work_location_id"/>
                <field name="x_member_program"/>
                <field name="x_public_profile_visibility"/>
                <field name="x_public_profile_ready"/>
                <field name="x_contract_sent_at"/>
                <field name="state"/>
                <field name="date_start"/>
                <field name="date_end"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_website_team_contract_search" model="ir.ui.view">
        <field name="name">hr.contract.search.website.manager.team</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="x_work_location_id"/>
                <field name="x_public_profile_visibility"/>
                <filter name="filter_visible" string="Visible" domain="[('x_public_profile_visibility', 'in', ['without_photo', 'with_photo'])]"/>
                <filter name="filter_with_photo" string="With Photo" domain="[('x_public_profile_visibility', '=', 'with_photo')]"/>
                <filter name="filter_hidden" string="Hidden" domain="[('x_public_profile_visibility', '=', 'hidden')]"/>
                <filter name="filter_incomplete" string="Incomplete Profile" domain="[('x_public_profile_ready', '=', False)]"/>
                <filter name="filter_missing_photo" string="Missing Photo" domain="[('x_public_profile_visibility', '=', 'with_photo'), ('employee_id.image_1920', '=', False)]"/>
                <separator/>
                <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                <filter name="group_by_position" string="Position" context="{'group_by': 'job_id'}"/>
                <filter name="group_by_visibility" string="Visibility" context="{'group_by': 'x_public_profile_visibility'}"/>
            </search>
        </field>
    </record>

    <record id="x_180dc_website_team_contract_action" model="ir.actions.act_window">
        <field name="name">Team Visibility</field>
        <field name="res_model">hr.contract</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="x_180dc_website_team_contract_list"/>
        <field name="search_view_id" ref="x_180dc_website_team_contract_search"/>
        <field name="domain">[('contract_type_id', '=', ref('x_180dc_member_contract.x_180dc_contract_type_membership'))]</field>
        <field name="context">{'search_default_filter_visible': 1}</field>
    </record>

    <record id="x_180dc_website_department_list" model="ir.ui.view">
        <field name="name">hr.department.list.website.manager</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <list default_order="name asc, id asc">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="x_public_description"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_website_department_search" model="ir.ui.view">
        <field name="name">hr.department.search.website.manager</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="manager_id"/>
                <filter name="filter_missing_description" string="Missing Public Description" domain="[('x_public_description', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="x_180dc_website_department_action" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="x_180dc_website_department_list"/>
        <field name="search_view_id" ref="x_180dc_website_department_search"/>
    </record>

    <record id="x_180dc_website_job_list" model="ir.ui.view">
        <field name="name">hr.job.list.website.manager</field>
        <field name="model">hr.job</field>
        <field name="arch" type="xml">
            <list default_order="department_id, name, id">
                <field name="name"/>
                <field name="department_id"/>
                <field name="x_open_for_applications"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="x_180dc_website_job_search" model="ir.ui.view">
        <field name="name">hr.job.search.website.manager</field>
        <field name="model">hr.job</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="department_id"/>
                <filter name="filter_missing_description" string="Missing Role Description" domain="[('description', '=', False)]"/>
                <filter name="filter_open_positions" string="Open for Applications" domain="[('active', '=', True), ('x_open_for_applications', '=', True)]"/>
                <separator/>
                <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
            </search>
        </field>
    </record>

    <record id="x_180dc_website_job_action" model="ir.actions.act_window">
        <field name="name">Positions</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="x_180dc_website_job_list"/>
        <field name="search_view_id" ref="x_180dc_website_job_search"/>
        <field name="context">{'search_default_filter_open_positions': 1}</field>
    </record>

