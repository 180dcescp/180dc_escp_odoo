<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_website_content_res_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.website.content</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="x_180dc_operating_model.x_180dc_operating_model_res_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='x_mailing_opt_out']/ancestor::page[1]" position="after">
                <page string="Website">
                    <group>
                        <field name="x_public_logo_url" placeholder="https://..."/>
                        <field name="x_public_sector_label"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
