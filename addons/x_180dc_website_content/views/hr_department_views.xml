<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_website_content_hr_department_form" model="ir.ui.view">
        <field name="name">hr.department.form.website.content</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='manager_id']" position="after">
                <field name="x_public_description" placeholder="Public-facing department description."/>
            </xpath>
        </field>
    </record>
</odoo>
