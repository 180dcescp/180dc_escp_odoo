<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="x_180dc_website_content_hr_job_form" model="ir.ui.view">
        <field name="name">hr.job.form.website.content</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="x_180dc_operating_model.x_180dc_operating_model_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='recruitment_page']" position="inside">
                <group string="Website Recruitment">
                    <field name="x_open_for_applications"/>
                </group>
                <group string="180DC Public Role Description">
                    <field name="description" placeholder="Public-facing description for this department / position."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
