<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="x_180dc_website_content.WebsiteDashboardAction">
        <div class="o_x_180dc_website_dashboard">
            <div class="o_x_180dc_website_dashboard__header">
                <div>
                    <h1>Website Manager</h1>
                    <p>Monitor public-site readiness and jump into the source records that need work.</p>
                </div>
                <button type="button" class="btn btn-primary" t-on-click="reload">Refresh</button>
            </div>

            <t t-if="state.loading">
                <div class="o_x_180dc_website_dashboard__panel">
                    <p>Loading dashboard…</p>
                </div>
            </t>

            <t t-elif="state.error">
                <div class="o_x_180dc_website_dashboard__panel o_x_180dc_website_dashboard__panel--error">
                    <p t-esc="state.error"/>
                </div>
            </t>

            <t t-else="">
                <div class="o_x_180dc_website_dashboard__summary">
                    <t t-foreach="state.payload.summaryCards" t-as="card" t-key="card.key">
                        <div class="o_x_180dc_website_dashboard__summary_card">
                            <span class="o_x_180dc_website_dashboard__summary_label" t-esc="card.label"/>
                            <strong class="o_x_180dc_website_dashboard__summary_value" t-esc="card.value"/>
                            <small t-esc="card.help"/>
                        </div>
                    </t>
                </div>

                <div class="o_x_180dc_website_dashboard__panel">
                    <div class="o_x_180dc_website_dashboard__panel_header">
                        <h2>Quick Actions</h2>
                        <small>
                            <t t-esc="state.payload.siteSettings.siteName"/>
                            <span> · </span>
                            <t t-esc="state.payload.siteSettings.contactEmail"/>
                        </small>
                    </div>
                    <div class="o_x_180dc_website_dashboard__quick_actions">
                        <t t-foreach="state.payload.quickActions" t-as="action" t-key="action.actionXmlId">
                            <button type="button" class="o_x_180dc_website_dashboard__quick_action" t-on-click="() => this.openAction(action.actionXmlId)">
                                <strong t-esc="action.label"/>
                                <span t-esc="action.description"/>
                            </button>
                        </t>
                    </div>
                </div>

                <div class="o_x_180dc_website_dashboard__grid">
                    <div class="o_x_180dc_website_dashboard__panel">
                        <div class="o_x_180dc_website_dashboard__panel_header">
                            <h2>Disclosure Risks</h2>
                            <button type="button" class="btn btn-link" t-on-click="() => this.openAction('x_180dc_website_content.x_180dc_website_engagement_action')">Open engagements</button>
                        </div>
                        <h3>Logo Fallbacks</h3>
                        <t t-if="state.payload.healthQueues.logoFallbacks.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.healthQueues.logoFallbacks" t-as="item" t-key="'logo-' + item.id">
                                    <li>
                                        <strong t-esc="item.name"/>
                                        <span>
                                            <t t-esc="item.client"/>
                                            <span> · </span>
                                            <t t-esc="item.configuredVisibility"/>
                                            <span> → </span>
                                            <t t-esc="item.effectiveVisibility"/>
                                        </span>
                                    </li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>No disclosure/logo conflicts detected.</p>
                        </t>

                        <h3>Missing Project Slugs</h3>
                        <t t-if="state.payload.healthQueues.missingProjectSlugs.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.healthQueues.missingProjectSlugs" t-as="item" t-key="'slug-' + item.id">
                                    <li>
                                        <strong t-esc="item.name"/>
                                        <span>
                                            <t t-esc="item.client"/>
                                            <span> · </span>
                                            <t t-esc="item.configuredVisibility"/>
                                        </span>
                                    </li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>No publishable engagements are missing a slug.</p>
                        </t>
                    </div>

                    <div class="o_x_180dc_website_dashboard__panel">
                        <div class="o_x_180dc_website_dashboard__panel_header">
                            <h2>Team Visibility</h2>
                            <button type="button" class="btn btn-link" t-on-click="() => this.openAction('x_180dc_website_content.x_180dc_website_team_contract_action')">Open contracts</button>
                        </div>
                        <t t-if="state.payload.healthQueues.incompleteProfiles.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.healthQueues.incompleteProfiles" t-as="item" t-key="'contract-' + item.id">
                                    <li>
                                        <strong t-esc="item.member"/>
                                        <span>
                                            <t t-esc="item.department"/>
                                            <span t-if="item.position"> / <t t-esc="item.position"/></span>
                                            <span> · </span>
                                            <t t-esc="item.visibility"/>
                                        </span>
                                        <small t-esc="item.missingFields.join(', ')"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>All current membership contracts are complete for website use.</p>
                        </t>
                    </div>

                    <div class="o_x_180dc_website_dashboard__panel">
                        <div class="o_x_180dc_website_dashboard__panel_header">
                            <h2>Role Catalog</h2>
                            <button type="button" class="btn btn-link" t-on-click="() => this.openAction('x_180dc_website_content.x_180dc_website_department_action')">Open catalog</button>
                        </div>
                        <div class="o_x_180dc_website_dashboard__catalog_stats">
                            <div>
                                <strong t-esc="state.payload.catalogStatus.departmentsDescribed"/>
                                <span>Departments described</span>
                            </div>
                            <div>
                                <strong t-esc="state.payload.catalogStatus.positionsWithDescription"/>
                                <span>Positions with description</span>
                            </div>
                            <div>
                                <strong t-esc="state.payload.catalogStatus.positionsCurrentlyOpen"/>
                                <span>Positions currently open</span>
                            </div>
                        </div>

                        <h3>Departments Missing Description</h3>
                        <t t-if="state.payload.healthQueues.departmentsMissingDescription.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.healthQueues.departmentsMissingDescription" t-as="item" t-key="'department-' + item.id">
                                    <li><strong t-esc="item.name"/></li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>All departments have a public description.</p>
                        </t>

                        <h3>Positions Missing Description</h3>
                        <t t-if="state.payload.healthQueues.jobsMissingDescription.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.healthQueues.jobsMissingDescription" t-as="item" t-key="'job-' + item.id">
                                    <li>
                                        <strong t-esc="item.name"/>
                                        <span t-esc="item.department"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>All positions have a public description.</p>
                        </t>
                    </div>

                    <div class="o_x_180dc_website_dashboard__panel">
                        <div class="o_x_180dc_website_dashboard__panel_header">
                            <h2>Scheduled Disclosure Changes</h2>
                            <button type="button" class="btn btn-link" t-on-click="() => this.openAction('x_180dc_website_content.x_180dc_website_engagement_action')">Review schedule</button>
                        </div>
                        <t t-if="state.payload.scheduledChanges.length">
                            <ul class="o_x_180dc_website_dashboard__list">
                                <t t-foreach="state.payload.scheduledChanges" t-as="item" t-key="'scheduled-' + item.id">
                                    <li>
                                        <strong t-esc="item.name"/>
                                        <span>
                                            <t t-if="item.client">
                                                <t t-esc="item.client"/>
                                                <span> · </span>
                                            </t>
                                            <t t-esc="item.currentVisibility"/>
                                            <span> → </span>
                                            <t t-esc="item.scheduledVisibility"/>
                                        </span>
                                        <small t-esc="item.scheduledAt"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                        <t t-else="">
                            <p>No scheduled disclosure changes are currently configured.</p>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
